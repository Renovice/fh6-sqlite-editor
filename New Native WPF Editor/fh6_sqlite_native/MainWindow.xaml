<Window x:Class="FH6SQLiteEditorNative.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FH6SQLiteEditorNative"
        Title="FH6 SQLite Editor Native"
        Width="1360"
        Height="860"
        MinWidth="1040"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Window.Resources>
        <SolidColorBrush x:Key="AppBgBrush" Color="#eef2f4"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#ffffff"/>
        <SolidColorBrush x:Key="SurfaceSoftBrush" Color="#f6f8f9"/>
        <SolidColorBrush x:Key="ChromeBrush" Color="#fbfcfd"/>
        <SolidColorBrush x:Key="LineBrush" Color="#d6e0e4"/>
        <SolidColorBrush x:Key="TextBrush" Color="#142025"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#64747b"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#086f83"/>
        <SolidColorBrush x:Key="SelectionBrush" Color="#c8eaf0"/>
        <ControlTemplate x:Key="ScrollBarRepeatButtonTemplate" TargetType="{x:Type RepeatButton}">
            <Border Background="Transparent"/>
        </ControlTemplate>
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="14"/>
            <Setter Property="MinWidth" Value="14"/>
            <Setter Property="Background" Value="{DynamicResource ChromeBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource LineBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="ScrollBarRoot"
                              Width="{TemplateBinding Width}"
                              Height="{TemplateBinding Height}"
                              Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True" Focusable="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton x:Name="DecreaseButton"
                                                  Command="{x:Static ScrollBar.PageUpCommand}"
                                                  Template="{StaticResource ScrollBarRepeatButtonTemplate}"
                                                  Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="ScrollThumb"
                                           MinHeight="28"
                                           Background="{DynamicResource LineBrush}"
                                           BorderBrush="{DynamicResource AccentBrush}">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border x:Name="ThumbBorder"
                                                        Margin="2"
                                                        CornerRadius="6"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="0"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton x:Name="IncreaseButton"
                                                  Command="{x:Static ScrollBar.PageDownCommand}"
                                                  Template="{StaticResource ScrollBarRepeatButtonTemplate}"
                                                  Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Width" Value="Auto"/>
                                <Setter Property="Height" Value="14"/>
                                <Setter Property="MinWidth" Value="0"/>
                                <Setter Property="MinHeight" Value="14"/>
                                <Setter TargetName="ScrollBarRoot" Property="Width" Value="Auto"/>
                                <Setter TargetName="ScrollBarRoot" Property="Height" Value="14"/>
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                                <Setter TargetName="DecreaseButton" Property="Command" Value="{x:Static ScrollBar.PageLeftCommand}"/>
                                <Setter TargetName="IncreaseButton" Property="Command" Value="{x:Static ScrollBar.PageRightCommand}"/>
                                <Setter TargetName="ScrollThumb" Property="MinHeight" Value="0"/>
                                <Setter TargetName="ScrollThumb" Property="MinWidth" Value="28"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TopButton" TargetType="{x:Type Button}">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="11,6"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}"/>
        </Style>
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextBrush}"/>
        </Style>
        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton x:Name="DropDownToggle"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border x:Name="ToggleBorder"
                                                MinHeight="{TemplateBinding MinHeight}"
                                                Background="{DynamicResource SurfaceBrush}"
                                                BorderBrush="{DynamicResource LineBrush}"
                                                BorderThickness="1"
                                                CornerRadius="0">
                                            <Grid>
                                                <ContentPresenter Margin="8,0,28,0"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Stretch"
                                                                  RecognizesAccessKey="True"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType={x:Type ComboBox}}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType={x:Type ComboBox}}}"
                                                                  ContentStringFormat="{Binding SelectionBoxItemStringFormat, RelativeSource={RelativeSource AncestorType={x:Type ComboBox}}}"/>
                                                <Path x:Name="Arrow"
                                                      Width="9"
                                                      Height="5"
                                                      Margin="0,0,10,0"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Fill="{DynamicResource TextBrush}"
                                                      Data="M 0 0 L 4.5 5 L 9 0 Z"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="ToggleBorder" Property="Opacity" Value="0.55"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Fade">
                                <Border x:Name="PopupBorder"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource LineBrush}"
                                        BorderThickness="1">
                                    <ScrollViewer CanContentScroll="True">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="PopupBorder" Property="MinHeight" Value="32"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Padding" Value="7,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SelectionBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SelectionBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SelectionBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SelectionBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="{x:Type ListBoxItem}">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ChromeBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SurfaceSoftBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SelectionBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="{x:Type TabItem}">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border x:Name="TabBorder"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource LineBrush}"
                                BorderThickness="1"
                                Padding="{TemplateBinding Padding}"
                                Margin="0,0,2,0">
                            <ContentPresenter x:Name="ContentSite"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              ContentSource="Header"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceSoftBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}"/>
            <Setter Property="Padding" Value="7,5"/>
        </Style>
        <Style TargetType="{x:Type DataGridRow}">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        </Style>
        <Style TargetType="{x:Type DataGridCell}">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SelectionBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="CanUserAddRows" Value="True"/>
            <Setter Property="CanUserDeleteRows" Value="True"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
            <Setter Property="EnableColumnVirtualization" Value="True"/>
            <Setter Property="AutoGenerateColumns" Value="True"/>
            <Setter Property="HeadersVisibility" Value="All"/>
            <Setter Property="SelectionUnit" Value="CellOrRowHeader"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="RowBackground" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource SurfaceSoftBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource LineBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource LineBrush}"/>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border x:Name="TopBar" Grid.Row="0" BorderThickness="0,0,0,1">
            <Grid Margin="16,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border x:Name="AppMark" Width="42" Height="42" CornerRadius="8" Margin="0,0,12,0">
                        <TextBlock Text="FH6" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="SQLite Editor" FontSize="20" FontWeight="SemiBold"/>
                        <TextBlock x:Name="StatusText" Text="No database loaded" FontSize="12" TextTrimming="CharacterEllipsis" MaxWidth="760"/>
                    </StackPanel>
                </StackPanel>

                <WrapPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Border x:Name="ConnectionPill" CornerRadius="13" BorderThickness="1" Padding="10,5" Margin="0,0,6,0">
                        <TextBlock x:Name="ConnectionStateText" Text="Local" FontSize="12" FontWeight="SemiBold"/>
                    </Border>
                    <Button x:Name="ThemeButton" Style="{StaticResource TopButton}" Content="Dark" Click="ThemeButton_Click"/>
                    <Button x:Name="OpenDbButton" Style="{StaticResource TopButton}" Content="Open DB" Click="OpenDbButton_Click"/>
                    <Button x:Name="DumpButton" Style="{StaticResource TopButton}" Content="Dump from Game" Click="DumpButton_Click"/>
                    <Button x:Name="SaveAsButton" Style="{StaticResource TopButton}" Content="Save As" Click="SaveAsButton_Click"/>
                    <Button x:Name="ImportButton" Style="{StaticResource TopButton}" Content="Import to Game" Click="ImportButton_Click"/>
                    <Button x:Name="ResetGameButton" Style="{StaticResource TopButton}" Content="Reset Game to Base" Click="ResetGameButton_Click"/>
                    <Button x:Name="ValidateButton" Style="{StaticResource TopButton}" Content="Validate" Click="ValidateButton_Click"/>
                    <Button x:Name="CancelTaskButton" Style="{StaticResource TopButton}" Content="Cancel" Click="CancelTaskButton_Click" Visibility="Collapsed"/>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="Sidebar" Grid.Column="0" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Margin="14">
                        <TextBlock Text="Cars" FontWeight="Bold" FontSize="12" Margin="0,0,0,10"/>
                        <TextBlock Text="Search" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="SearchBox" TextChanged="SearchBox_TextChanged"/>
                        <TextBlock Text="Filter" FontSize="11" FontWeight="SemiBold" Margin="0,10,0,4"/>
                        <ComboBox x:Name="VisibilityFilter" SelectionChanged="VisibilityFilter_SelectionChanged">
                            <ComboBoxItem Content="All cars" Tag="all" IsSelected="True"/>
                            <ComboBoxItem Content="Autoshow visible" Tag="visible"/>
                            <ComboBoxItem Content="Hidden from Autoshow" Tag="autoshow"/>
                            <ComboBoxItem Content="Hidden from Auction House" Tag="auction"/>
                        </ComboBox>
                    </StackPanel>

                    <ListBox x:Name="CarListBox"
                             Grid.Row="1"
                             Margin="0"
                             BorderThickness="0"
                             SelectionChanged="CarListBox_SelectionChanged"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:CarListItem}">
                                <StackPanel Margin="12,7">
                                    <TextBlock Text="{Binding Title}" TextWrapping="Wrap" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Subtitle}" FontSize="12"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="150"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock x:Name="CarTitleText" Text="Select a car" FontSize="22" FontWeight="SemiBold"/>
                        <TextBlock x:Name="CarSubtitleText" Text="Or open any table from the tabs below." FontSize="12"/>
                    </StackPanel>
                </StackPanel>

                <TabControl x:Name="EditorTabs" Grid.Row="1" SelectionChanged="EditorTabs_SelectionChanged">
                    <TabItem Header="Core"/>
                    <TabItem Header="Engines"/>
                    <TabItem Header="Engine Parts"/>
                    <TabItem Header="Defaults"/>
                    <TabItem Header="Upgrades"/>
                    <TabItem Header="Aero"/>
                    <TabItem Header="Lookups"/>
                    <TabItem Header="Tuning Limits"/>
                    <TabItem Header="Validate"/>
                    <TabItem Header="All Tables"/>
                </TabControl>

                <Border x:Name="TableToolbar" Grid.Row="2" BorderThickness="0,0,0,1" Padding="0,10,0,10">
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <WrapPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                                <TextBlock Text="Table" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ComboBox x:Name="TableCombo" Width="270" SelectionChanged="TableCombo_SelectionChanged"/>
                                <TextBlock Text="Search" VerticalAlignment="Center" Margin="12,0,8,0"/>
                                <TextBox x:Name="TableSearchBox" Width="240" TextChanged="TableSearchBox_TextChanged"/>
                                <Button x:Name="RefreshTableButton" Content="Refresh" Style="{StaticResource TopButton}" Click="RefreshTableButton_Click"/>
                                <Button x:Name="ApplyChangesButton" Content="Apply Edits" Style="{StaticResource TopButton}" Click="ApplyChangesButton_Click"/>
                                <Button x:Name="AddLinkedOptionButton" Content="Add Option" Style="{StaticResource TopButton}" Click="AddLinkedOptionButton_Click" Visibility="Collapsed"/>
                                <Button x:Name="WireMenuButton" Content="Wire Menu" Style="{StaticResource TopButton}" Click="WireMenuButton_Click" Visibility="Collapsed"/>
                            </WrapPanel>
                            <StackPanel x:Name="TemplatePanel" Orientation="Horizontal" DockPanel.Dock="Right" Visibility="Collapsed">
                                <TextBlock Text="EngineID" VerticalAlignment="Center" Margin="10,0,6,0"/>
                                <TextBox x:Name="TemplateEngineIdBox" Width="90"/>
                                <ComboBox x:Name="TemplateCombo" Width="340" Margin="8,0,0,0"/>
                                <Button x:Name="AddTemplateButton" Content="Add From Template" Style="{StaticResource TopButton}" Click="AddTemplateButton_Click"/>
                            </StackPanel>
                        </DockPanel>

                        <TextBlock x:Name="RoleLegendText"
                                   Text="Role guide: Effect = edit this for actual part/physics behavior, like MassDiff or tire width. Base = stock car/engine value, like CurbWeight. Reference = catalog/source value; existing upgrades do not auto-update from it, like EngineMass-kg. Display = menu/stat text like PI, class, names, ratings, graph numbers. Visual = model/graphics only. Menu = price/order/stock/unlock info. Selector = ID link to another row. Derived = read-only editor helper."
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0"/>

                        <Border x:Name="EngineToolsPanel" Margin="0,10,0,0" Padding="10" BorderThickness="1" CornerRadius="8" Visibility="Collapsed">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <WrapPanel>
                                    <StackPanel Width="260" Margin="0,0,10,8">
                                        <TextBlock Text="Current Car Engines" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="CarEngineCombo"/>
                                    </StackPanel>
                                    <Button x:Name="LoadEngineSwapsButton" Content="Engine Swaps" Style="{StaticResource TopButton}" Margin="0,18,4,8" Click="LoadEngineSwapsButton_Click"/>
                                    <Button x:Name="LoadBaseEngineButton" Content="Base Engine Stats" Style="{StaticResource TopButton}" Margin="0,18,14,8" Click="LoadBaseEngineButton_Click"/>
                                    <StackPanel Width="260" Margin="0,0,10,8">
                                        <TextBlock Text="Engine Catalog Search" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <TextBox x:Name="EngineSearchBox" TextChanged="EngineSearchBox_TextChanged"/>
                                    </StackPanel>
                                    <StackPanel Width="390" Margin="0,0,10,8">
                                        <TextBlock Text="Engine" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="EngineCatalogCombo"/>
                                    </StackPanel>
                                    <Button x:Name="AddEngineSwapButton" Content="Add Swap" Style="{StaticResource TopButton}" Margin="0,18,0,8" Click="AddEngineSwapButton_Click"/>
                                </WrapPanel>
                                <TextBlock x:Name="EnginePanelNote" Grid.Row="1" Text="Adds a List_UpgradeEngine row for the selected car using the stock row as a template." FontSize="12"/>
                            </Grid>
                        </Border>

                        <Border x:Name="PartToolsPanel" Margin="0,10,0,0" Padding="10" BorderThickness="1" CornerRadius="8" Visibility="Collapsed">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <WrapPanel>
                                    <StackPanel Width="300" Margin="0,0,10,8">
                                        <TextBlock Text="Engine" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="PartEngineCombo" SelectionChanged="PartEngineCombo_SelectionChanged"/>
                                    </StackPanel>
                                    <StackPanel Width="280" Margin="0,0,10,8">
                                        <TextBlock Text="Part Table" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="PartTableCombo" SelectionChanged="PartTableCombo_SelectionChanged"/>
                                    </StackPanel>
                                    <Button x:Name="LoadPartRowsButton" Content="Load" Style="{StaticResource TopButton}" Margin="0,18,14,8" Click="LoadPartRowsButton_Click"/>
                                    <StackPanel Width="520" Margin="0,0,10,8">
                                        <TextBlock Text="Copy Values From" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="PartTemplateCombo"/>
                                    </StackPanel>
                                    <Button x:Name="AddPartOptionButton" Content="Add Option" Style="{StaticResource TopButton}" Margin="0,18,4,8" Click="AddPartOptionButton_Click"/>
                                    <Button x:Name="EnableAspirationTypeButton" Content="Wire Menu" Style="{StaticResource TopButton}" Margin="0,18,14,8" Click="EnableAspirationTypeButton_Click" Visibility="Collapsed"/>
                                    <Button x:Name="ProbeMenuButton" Content="Probe Menu" Style="{StaticResource TopButton}" Margin="0,18,14,8" Click="ProbeMenuButton_Click"/>
                                    <StackPanel Width="380" Margin="0,0,10,8">
                                        <TextBlock Text="Aspiration Conversion" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="AspirationConversionCombo"/>
                                    </StackPanel>
                                    <Button x:Name="AddAspirationConversionButton" Content="Add Conversion" Style="{StaticResource TopButton}" Margin="0,18,4,8" Click="AddAspirationConversionButton_Click"/>
                                    <Button x:Name="RemoveAspirationConversionButton" Content="Remove Conversion" Style="{StaticResource TopButton}" Margin="0,18,0,8" Click="RemoveAspirationConversionButton_Click"/>
                                </WrapPanel>
                                <TextBlock x:Name="PartPanelNote" Grid.Row="1" Text="Pick an engine and part table, then copy a compatible template row into that engine." FontSize="12"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="3" Margin="0,12,0,10">
                    <Border x:Name="FieldFormBorder" BorderThickness="1" CornerRadius="8" Padding="12" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <WrapPanel x:Name="FieldFormPanel" Orientation="Horizontal"/>
                        </ScrollViewer>
                    </Border>
                    <Border x:Name="HtmlTableBorder" BorderThickness="1" CornerRadius="8" Padding="0" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <Grid x:Name="HtmlTableGrid"/>
                        </ScrollViewer>
                    </Border>
                    <Border x:Name="ValidatePanel" BorderThickness="1" CornerRadius="8" Padding="14" Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="Database Validation" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Button Content="Run Integrity Check" Style="{StaticResource TopButton}" Click="RunValidateTabButton_Click"/>
                            </StackPanel>
                            <TextBox x:Name="ValidateResultBox"
                                     Grid.Row="1"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"/>
                        </Grid>
                    </Border>
                    <Border x:Name="MenuProbePanel" BorderThickness="1" CornerRadius="8" Padding="14" Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="Upgrade Menu Probe" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Button Content="Refresh Probe" Style="{StaticResource TopButton}" Click="ProbeMenuButton_Click"/>
                            </StackPanel>
                            <TextBox x:Name="MenuProbeResultBox"
                                     Grid.Row="1"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="NoWrap"
                                     HorizontalScrollBarVisibility="Auto"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"/>
                        </Grid>
                    </Border>
                    <DataGrid x:Name="TableGrid"
                              AutoGeneratingColumn="TableGrid_AutoGeneratingColumn"/>
                </Grid>

                <Grid Grid.Row="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="TableStatusText" Text="Ready" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox x:Name="LogBox"
                             Grid.Row="1"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="12"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
